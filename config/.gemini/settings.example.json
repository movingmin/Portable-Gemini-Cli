{
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "mcpServers": {
    "github": {
      "command": "node",
      "args": [
        "./MCP/github-server/node_modules/@modelcontextprotocol/server-github/dist/index.js"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    },
    "notionApi": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_TOKEN": "YOUR_NOTION_TOKEN_HERE"
      }
    },
    "word-document-server": {
      "command": "./python/python.exe",
      "args": [
        "./MCP/Office-Word-MCP-Server/word_mcp_server.py"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio"
      }
    },
    "ppt-server": {
      "command": "./python/python.exe",
      "args": [
        "./MCP/Office-PowerPoint-MCP-Server/ppt_mcp_server.py"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "PPT_TEMPLATE_PATH": "./MCP/Office-PowerPoint-MCP-Server/templates"
      }
    },
    "excel": {
      "command": "./python/python.exe",
      "args": [
        "-m",
        "excel_mcp",
        "stdio"
      ]
    },
    "pdf-math-translate": {
      "command": "./python/python.exe",
      "args": [
        "-m",
        "pdf2zh",
        "--mcp"
      ]
    },
    "playwright": {
      "command": "node",
      "args": [
        "./MCP/playwright-MCP-Server/node_modules/@executeautomation/playwright-mcp-server/dist/index.js"
      ],
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "./cache/ms-playwright"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics"
      ],
      "env": {
        "CHROME_PATH": "%GOOGLE_CHROME_BIN%"
      }
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-fetch-server"
      ]
    },
    "kubernetes": {
      "command": "npx",
      "args": [
        "-y",
        "kubernetes-mcp-server@latest"
      ]
    }
  }
}